      content_zh: (document.getElementById('newsContentZh') as HTMLTextAreaElement).value.split(/\n\s*\n/).filter((p: string) => p.trim() !== '')
    };
    let updated = [...newsData];
    if (isNew) { updated.unshift(newItem); }
    else { updated = updated.map((n: any) => n.slug === slug ? newItem : n); }
    await submitNewsData(updated);
    deleteNewsBtn.classList.remove('hidden');
    (document.getElementById('newsIsNew') as HTMLInputElement).value = '0';
