---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { verifyToken } from '../../lib/auth';
import { ghReadJson } from '../../lib/github';

// Auth guard
const token = Astro.cookies.get('admin_token')?.value;
if (!token || !(await verifyToken(token))) {
  return Astro.redirect('/admin-tz-7360/login');
}

// Read current content from GitHub (always latest committed state)
type Capaian = { kode: string; label: string; label_zh?: string; desc: string; desc_zh?: string; };
type Proyek  = { id: string; nama: string; nama_zh?: string; klien: string; klien_zh?: string; lokasi: string; lokasi_zh?: string; foto: string; fotoAlt: string; deskripsi: string; deskripsi_zh?: string; capaian: Capaian[] };
type Alasan  = { angka: string; label: string };
type BlogPost = { slug: string; title: string; title_zh?: string; excerpt: string; excerpt_zh?: string; date: string; readTime: string; content: string[]; content_zh?: string[] };
type NewsItem = { slug: string; title: string; title_zh?: string; excerpt: string; excerpt_zh?: string; date: string; readTime: string; content: string[]; content_zh?: string[] };

let proyek: Proyek | null = null;
let alasan: Alasan[] = [];
let blogs: BlogPost[] = [];
let newsItems: NewsItem[] = [];
let loadError = '';

try {
  const ghConfigured = import.meta.env.GITHUB_TOKEN && import.meta.env.GITHUB_REPO;
  if (ghConfigured) {
    const { data: pd } = await ghReadJson('src/data/portfolio.json') as { data: { proyek: Proyek[] }; sha: string };
    proyek = pd.proyek?.[0] ?? null;
    const { data: sc } = await ghReadJson('src/data/site-content.json') as { data: { alasan: Alasan[] }; sha: string };
    alasan = sc.alasan ?? [];
    const { data: bc } = await ghReadJson('src/data/blog.json') as { data: BlogPost[]; sha: string };
    blogs = bc ?? [];
    const { data: nc } = await ghReadJson('src/data/news.json') as { data: NewsItem[]; sha: string };
    newsItems = nc ?? [];
  } else {
    loadError = 'GITHUB_TOKEN atau GITHUB_REPO belum diset di environment variables.';
  }
} catch (e) {
  loadError = `Gagal memuat konten dari GitHub: ${e}`;
}
---

<AdminLayout title="Dashboard">
  <!-- TOP NAV BAR -->
  <header class="sticky top-0 z-50 border-b border-white/10 bg-blueprint-dark px-5 py-3">
    <div class="mx-auto flex max-w-5xl items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="font-display text-base font-bold text-paper">ESTER GLOBALINDO</span>
        <span class="rounded-sm bg-stamp px-1.5 py-0.5 font-mono text-[10px] font-medium tracking-wider text-paper">ADMIN</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" target="_blank" rel="noopener noreferrer"
           class="font-mono text-xs text-blueprint-light underline underline-offset-2 hover:text-paper">
          Lihat Website &rarr;
        </a>
        <button id="logoutBtn"
          class="rounded-sm border border-white/20 px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-blueprint-light transition-colors hover:border-stamp hover:text-stamp">
          Logout
        </button>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-5 py-10">

    <!-- Page title -->
    <div class="mb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">Panel Admin</p>
      <h1 class="mt-1 font-display text-3xl font-bold text-ink">Edit Konten Website</h1>
      <p class="mt-2 font-body text-sm text-slate">
        Perubahan yang disimpan akan otomatis tampil di website dalam <strong class="text-ink">1–2 menit</strong> (waktu redeploy Vercel).
      </p>
    </div>

    <!-- Error banner -->
    {loadError && (
      <div class="mb-8 rounded-sm border-2 border-stamp bg-stamp/10 px-5 py-4">
        <p class="font-mono text-xs uppercase tracking-wider text-stamp mb-1">Perhatian</p>
        <p class="font-body text-sm text-ink">{loadError}</p>
        <p class="mt-2 font-mono text-xs text-slate">Pastikan semua environment variables sudah diset di Vercel dashboard.</p>
      </div>
    )}

    <!-- TABS -->
    <div class="mb-6 flex gap-1 border-b-2 border-line overflow-x-auto">
      <button id="tab-portofolio" data-tab="portofolio"
        class="tab-btn rounded-t-sm px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors bg-ink text-paper whitespace-nowrap">
        Portofolio
      </button>
      <button id="tab-stats" data-tab="stats"
        class="tab-btn rounded-t-sm px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors text-slate hover:text-ink whitespace-nowrap">
        Statistik
      </button>
      <button id="tab-blog" data-tab="blog"
        class="tab-btn rounded-t-sm px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors text-slate hover:text-ink whitespace-nowrap">
        Blog & Artikel
      </button>
      <button id="tab-berita" data-tab="berita"
        class="tab-btn rounded-t-sm px-5 py-2.5 font-mono text-xs uppercase tracking-wider transition-colors text-slate hover:text-ink whitespace-nowrap">
        Berita
      </button>
    </div>

    <!-- ===== PANEL: PORTOFOLIO ===== -->
    <section id="panel-portofolio" class="tab-panel">
      <div class="rounded-sm border-2 border-line bg-paper p-8">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-stamp">Proyek</p>
            <h2 class="mt-1 font-display text-xl font-bold text-ink">Prodia Laboratory Mojokerto</h2>
          </div>
          <a href="/portofolio" target="_blank" class="font-mono text-xs text-slate underline underline-offset-2 hover:text-ink">
            Lihat halaman &rarr;
          </a>
        </div>

        <form id="portfolioForm" novalidate>
          <div class="grid gap-5 sm:grid-cols-2">

            <div class="sm:col-span-2">
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Nama Proyek (ID)</label>
              <input name="nama" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint" required
                value={proyek?.nama ?? ''} />
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Nama Proyek (ZH)</label>
              <input name="nama_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                value={proyek?.nama_zh ?? ''} />
            </div>

            <div>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Klien (ID)</label>
              <input name="klien" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                value={proyek?.klien ?? ''} />
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Klien (ZH)</label>
              <input name="klien_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                value={proyek?.klien_zh ?? ''} />
            </div>

            <div>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Lokasi (ID)</label>
              <input name="lokasi" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                value={proyek?.lokasi ?? ''} />
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Lokasi (ZH)</label>
              <input name="lokasi_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                value={proyek?.lokasi_zh ?? ''} />
            </div>

            <div class="sm:col-span-2">
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Proyek (ID)</label>
              <textarea name="deskripsi" rows="4" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.deskripsi ?? ''}</textarea>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Proyek (ZH)</label>
              <textarea name="deskripsi_zh" rows="4" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.deskripsi_zh ?? ''}</textarea>
            </div>

            <!-- PBG -->
            <div class="sm:col-span-2 border-t border-line pt-5">
              <p class="mb-4 flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-slate">
                <span class="rounded-sm bg-blueprint px-2 py-0.5 text-paper">PBG</span>
                Capaian Persetujuan Bangunan Gedung
              </p>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Label (ID)</label>
                  <input name="pbg_label" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                    value={proyek?.capaian?.[0]?.label ?? 'Persetujuan Bangunan Gedung'} />
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Label (ZH)</label>
                  <input name="pbg_label_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                    value={proyek?.capaian?.[0]?.label_zh ?? ''} />
                </div>
                <div class="sm:row-span-2">
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Capaian (ID)</label>
                  <textarea name="pbg_desc" rows="4" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.capaian?.[0]?.desc ?? ''}</textarea>
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Capaian (ZH)</label>
                  <textarea name="pbg_desc_zh" rows="4" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.capaian?.[0]?.desc_zh ?? ''}</textarea>
                </div>
              </div>
            </div>

            <!-- SLF -->
            <div class="sm:col-span-2 border-t border-line pt-5">
              <p class="mb-4 flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-slate">
                <span class="rounded-sm bg-blueprint px-2 py-0.5 text-paper">SLF</span>
                Capaian Sertifikat Laik Fungsi
              </p>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Label (ID)</label>
                  <input name="slf_label" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                    value={proyek?.capaian?.[1]?.label ?? 'Sertifikat Laik Fungsi'} />
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Label (ZH)</label>
                  <input name="slf_label_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                    value={proyek?.capaian?.[1]?.label_zh ?? ''} />
                </div>
                <div class="sm:row-span-2">
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Capaian (ID)</label>
                  <textarea name="slf_desc" rows="4" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.capaian?.[1]?.desc ?? ''}</textarea>
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Deskripsi Capaian (ZH)</label>
                  <textarea name="slf_desc_zh" rows="4" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint resize-none">{proyek?.capaian?.[1]?.desc_zh ?? ''}</textarea>
                </div>
              </div>
            </div>

            <!-- IMAGE UPLOAD -->
            <div class="sm:col-span-2 border-t border-line pt-5">
              <p class="mb-4 font-mono text-xs uppercase tracking-widest text-slate">Foto Proyek</p>
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
                <!-- Preview -->
                <div class="relative h-40 w-full overflow-hidden rounded-sm border-2 border-line sm:w-56 flex-shrink-0">
                  <img id="imgPreview" src={proyek?.foto ?? '/images/prodia.jpg'}
                    alt="Preview foto proyek"
                    class="h-full w-full object-cover" />
                </div>
                <div class="flex flex-col justify-center gap-3">
                  <input type="hidden" id="fotoPath" name="foto" value={proyek?.foto ?? '/images/prodia.jpg'} />
                  <label
                    for="imageInput"
                    class="cursor-pointer rounded-sm border-2 border-ink px-5 py-2.5 text-center font-mono text-xs font-medium uppercase tracking-wider text-ink transition-colors hover:bg-ink hover:text-paper"
                  >
                    Pilih Foto Baru
                  </label>
                  <input id="imageInput" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
                  <p id="uploadStatus" class="font-mono text-xs text-slate">JPG / PNG / WebP, maks 5MB</p>
                </div>
              </div>
            </div>

          </div><!-- end grid -->

          <!-- Save status + button -->
          <div class="mt-8 flex flex-col gap-3 border-t border-line pt-6 sm:flex-row sm:items-center sm:justify-between">
            <p id="portfolioStatus" class="font-mono text-xs text-slate"></p>
            <button type="submit" id="savePortfolioBtn"
              class="rounded-sm bg-stamp px-8 py-3 font-mono text-sm font-medium uppercase tracking-wider text-paper transition-opacity hover:opacity-90 disabled:opacity-50">
              Simpan Perubahan
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- ===== PANEL: HOMEPAGE STATS ===== -->
    <section id="panel-stats" class="tab-panel hidden">
      <div class="rounded-sm border-2 border-line bg-paper p-8">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-stamp">Homepage</p>
            <h2 class="mt-1 font-display text-xl font-bold text-ink">Statistik & Angka Unggulan</h2>
          </div>
          <a href="/" target="_blank" class="font-mono text-xs text-slate underline underline-offset-2 hover:text-ink">
            Lihat halaman &rarr;
          </a>
        </div>
        <p class="mb-6 font-body text-sm text-slate">Angka-angka ini tampil di bagian atas halaman utama website.</p>

        <form id="statsForm" novalidate>
          <div class="space-y-4">
            {alasan.map((a, i) => (
              <div class="flex gap-4 rounded-sm border border-line p-4">
                <div class="w-24 flex-shrink-0">
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Angka</label>
                  <input name={`angka_${i}`} type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint text-center font-display font-bold"
                    value={a.angka} placeholder="12+" />
                </div>
                <div class="flex-1">
                  <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Label / Keterangan</label>
                  <input name={`label_${i}`} type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none transition-colors focus:border-blueprint"
                    value={a.label} />
                </div>
              </div>
            ))}
            {alasan.length === 0 && (
              <p class="font-body text-sm text-slate italic">Data tidak dapat dimuat. Periksa konfigurasi GitHub.</p>
            )}
          </div>

          <input type="hidden" name="count" value={String(alasan.length)} />

          <div class="mt-8 flex flex-col gap-3 border-t border-line pt-6 sm:flex-row sm:items-center sm:justify-between">
            <p id="statsStatus" class="font-mono text-xs text-slate"></p>
            <button type="submit" id="saveStatsBtn"
              class="rounded-sm bg-stamp px-8 py-3 font-mono text-sm font-medium uppercase tracking-wider text-paper transition-opacity hover:opacity-90 disabled:opacity-50">
              Simpan Perubahan
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- ===== PANEL: BLOG ===== -->
    <section id="panel-blog" class="tab-panel hidden">
      <div class="rounded-sm border-2 border-line bg-paper p-8">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-stamp">Artikel</p>
            <h2 class="mt-1 font-display text-xl font-bold text-ink">Manajemen Blog</h2>
          </div>
          <a href="/blog" target="_blank" class="font-mono text-xs text-slate underline underline-offset-2 hover:text-ink">
            Lihat blog &rarr;
          </a>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <select id="blogSelect" class="flex-1 rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm outline-none focus:border-blueprint text-ink">
            <option value="">-- Pilih Artikel untuk Diedit --</option>
            {blogs.map(b => (
              <option value={b.slug}>{b.title}</option>
            ))}
          </select>
          <button id="newBlogBtn" type="button" class="rounded-sm border-2 border-ink bg-paper px-6 py-2.5 font-mono text-xs uppercase font-medium tracking-wider text-ink transition-colors hover:bg-ink hover:text-paper whitespace-nowrap">
            + Artikel Baru
          </button>
        </div>

        <form id="blogForm" class="hidden" novalidate>
          <input type="hidden" id="blogSlug" name="slug" />
          <input type="hidden" id="blogIsNew" value="0" />
          
          <div class="grid gap-5">
            <div>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Judul Artikel (ID)</label>
              <input id="blogTitle" name="title" type="text" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint" required />
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Judul Artikel (ZH)</label>
              <input id="blogTitleZh" name="title_zh" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint" />
            </div>
            <div>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Ringkasan / Excerpt (ID)</label>
              <textarea id="blogExcerpt" name="excerpt" rows="2" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint resize-none" required></textarea>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Ringkasan / Excerpt (ZH)</label>
              <textarea id="blogExcerptZh" name="excerpt_zh" rows="2" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint resize-none"></textarea>
            </div>
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Tanggal (YYYY-MM-DD)</label>
                <input id="blogDate" name="date" type="date" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint" required />
              </div>
              <div>
                <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Waktu Baca</label>
                <input id="blogReadTime" name="readTime" type="text" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint" required placeholder="3 menit baca" />
              </div>
            </div>
            <div>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Konten (ID)</label>
              <textarea id="blogContent" name="content" rows="8" class="mb-3 w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint resize-y leading-relaxed" required></textarea>
              <label class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-slate">Konten (ZH)</label>
              <textarea id="blogContentZh" name="content_zh" rows="8" class="w-full rounded-sm border-2 border-line bg-paper-dim px-4 py-2.5 font-body text-sm text-ink outline-none focus:border-blueprint resize-y leading-relaxed"></textarea>
            </div>
          </div>
          
          <div class="mt-8 flex flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:items-center sm:justify-between">
            <p id="blogStatus" class="font-mono text-xs text-slate"></p>
            <div class="flex flex-col sm:flex-row gap-3">
              <button type="button" id="deleteBlogBtn" class="hidden rounded-sm border border-stamp px-6 py-3 font-mono text-sm font-medium uppercase tracking-wider text-stamp transition-opacity hover:bg-stamp hover:text-paper">
                Hapus
              </button>
              <button type="submit" id="saveBlogBtn" class="rounded-sm bg-stamp px-8 py-3 font-mono text-sm font-medium uppercase tracking-wider text-paper transition-opacity hover:opacity-90 disabled:opacity-50">
                Simpan Artikel
              </button>
            </div>
          </div>
        </form>
      </div>
    </section>

    <!-- ===== PANEL: BERITA ===== -->
    <section id="panel-berita" class="tab-panel hidden">
      <div class="rounded-sm border-2 border-line bg-paper p-8">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-stamp">Terkini</p>
            <h2 class="mt-1 font-display text-xl font-bold text-ink">Manajemen Berita</h2>
          </div>
          <a href="/berita" target="_blank" class="font-mono text-xs text-slate underline underline-offset-2 hover:text-ink">
            Lihat berita &rarr;
          </a>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
