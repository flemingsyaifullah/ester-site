<script>
  /* ---- Tab switching ---- */
  const tabBtns  = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  function activateTab(id: string) {
    tabBtns.forEach(b => {
      const active = b.dataset.tab === id;
      b.classList.toggle('bg-ink', active);
      b.classList.toggle('text-paper', active);
      b.classList.toggle('text-slate', !active);
    });
    tabPanels.forEach(p => {
      p.classList.toggle('hidden', p.id !== `panel-${id}`);
    });
  }
  tabBtns.forEach(b => b.addEventListener('click', () => activateTab(b.dataset.tab!)));

  /* ---- Logout ---- */
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await fetch('/api/admin-logout', { method: 'POST' });
    window.location.href = '/admin-tz-7360/login';
  });

  /* ---- Image upload ---- */
  const imageInput  = document.getElementById('imageInput') as HTMLInputElement;
  const imgPreview  = document.getElementById('imgPreview') as HTMLImageElement;
  const fotoPath    = document.getElementById('fotoPath') as HTMLInputElement;
  const uploadStatus = document.getElementById('uploadStatus') as HTMLParagraphElement;

  /* ---- Save portfolio (extracted as function so bisa dipanggil dari mana saja) ---- */
  const portfolioForm    = document.getElementById('portfolioForm') as HTMLFormElement;
  const portfolioStatus  = document.getElementById('portfolioStatus') as HTMLParagraphElement;
  const savePortfolioBtn = document.getElementById('savePortfolioBtn') as HTMLButtonElement;

  async function savePortfolio() {
    savePortfolioBtn.disabled = true;
    savePortfolioBtn.textContent = 'Menyimpan...';
    portfolioStatus.textContent = '';

    const fd = new FormData(portfolioForm);
    const payload = {
      proyek: [
        {
          id: 'prodia-mojokerto',
          nama: fd.get('nama')?.toString() ?? '',
          nama_zh: fd.get('nama_zh')?.toString() ?? '',
          klien: fd.get('klien')?.toString() ?? '',
          klien_zh: fd.get('klien_zh')?.toString() ?? '',
          lokasi: fd.get('lokasi')?.toString() ?? '',
          lokasi_zh: fd.get('lokasi_zh')?.toString() ?? '',
          foto: fd.get('foto')?.toString() ?? '/images/prodia.jpg',
          fotoAlt: fd.get('nama')?.toString() ?? 'Foto proyek',
          deskripsi: fd.get('deskripsi')?.toString() ?? '',
          deskripsi_zh: fd.get('deskripsi_zh')?.toString() ?? '',
          capaian: [
            {
              kode: 'PBG',
              label: fd.get('pbg_label')?.toString() ?? 'Persetujuan Bangunan Gedung',
              label_zh: fd.get('pbg_label_zh')?.toString() ?? '',
              desc: fd.get('pbg_desc')?.toString() ?? '',
              desc_zh: fd.get('pbg_desc_zh')?.toString() ?? '',
            },
            {
              kode: 'SLF',
              label: fd.get('slf_label')?.toString() ?? 'Sertifikat Laik Fungsi',
              label_zh: fd.get('slf_label_zh')?.toString() ?? '',
              desc: fd.get('slf_desc')?.toString() ?? '',
              desc_zh: fd.get('slf_desc_zh')?.toString() ?? '',
            },
          ],
        },
      ],
    };

    try {
      const res = await fetch('/api/save-portfolio', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        portfolioStatus.textContent = '✓ Tersimpan! Website akan diperbarui dalam ~1–2 menit.';
      } else {
        portfolioStatus.textContent = `✗ Gagal: ${data.error}`;
      }
    } catch (err) {
      portfolioStatus.textContent = `✗ Gagal: ${err}`;
    } finally {
      savePortfolioBtn.disabled = false;
      savePortfolioBtn.textContent = 'Simpan Perubahan';
    }
  }

  /* Upload foto: upload dulu, lalu langsung auto-save portfolio agar path foto ikut tersimpan */
  imageInput?.addEventListener('change', async () => {
    const file = imageInput.files?.[0];
    if (!file) return;

    // Tampilkan preview lokal dulu
    imgPreview.src = URL.createObjectURL(file);
    uploadStatus.textContent = 'Mengupload foto...';

    const fd = new FormData();
    fd.append('image', file);

    try {
      const res = await fetch('/api/upload-image', { method: 'POST', body: fd });
      const data = await res.json();
      if (res.ok && data.ok) {
        fotoPath.value = data.path;
        uploadStatus.textContent = `✓ Foto terupload! Menyimpan ke portfolio...`;
        // Auto-save agar portfolio.json langsung terupdate dengan path foto baru
        await savePortfolio();
        uploadStatus.textContent = `✓ Foto berhasil disimpan: ${data.path}`;
      } else {
        uploadStatus.textContent = `✗ Upload gagal: ${data.error}`;
      }
    } catch (e) {
      uploadStatus.textContent = `✗ Upload gagal: ${e}`;
    }
  });

  portfolioForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await savePortfolio();
  });

  /* ---- Save stats ---- */
  const statsForm   = document.getElementById('statsForm') as HTMLFormElement;
  const statsStatus = document.getElementById('statsStatus') as HTMLParagraphElement;
  const saveStatsBtn = document.getElementById('saveStatsBtn') as HTMLButtonElement;

  statsForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveStatsBtn.disabled = true;
    saveStatsBtn.textContent = 'Menyimpan...';
    statsStatus.textContent = '';

    const fd = new FormData(statsForm);
    const count = parseInt(fd.get('count')?.toString() ?? '3');
    const alasan = [];
    for (let i = 0; i < count; i++) {
      alasan.push({
        angka: fd.get(`angka_${i}`)?.toString() ?? '',
        label: fd.get(`label_${i}`)?.toString() ?? '',
      });
    }

    try {
      const res = await fetch('/api/save-content', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ alasan }),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        statsStatus.textContent = '✓ Tersimpan! Website akan diperbarui dalam ~1–2 menit.';
      } else {
        statsStatus.textContent = `✗ Gagal: ${data.error}`;
      }
    } catch (err) {
      statsStatus.textContent = `✗ Gagal: ${err}`;
    } finally {
      saveStatsBtn.disabled = false;
      saveStatsBtn.textContent = 'Simpan Perubahan';
    }
  });
</script>

<script id="blogDataScript" type="application/json" set:html={JSON.stringify(blogs)}></script>
<script>
  /* ---- Blog JS ---- */
  let blogsData = [];
  try {
    blogsData = JSON.parse(document.getElementById('blogDataScript')?.textContent || '[]');
  } catch(e) {}
  
  const blogSelect = document.getElementById('blogSelect') as HTMLSelectElement;
  const newBlogBtn = document.getElementById('newBlogBtn') as HTMLButtonElement;
  const blogForm = document.getElementById('blogForm') as HTMLFormElement;
  const deleteBlogBtn = document.getElementById('deleteBlogBtn') as HTMLButtonElement;
  const saveBlogBtn = document.getElementById('saveBlogBtn') as HTMLButtonElement;
  const blogStatus = document.getElementById('blogStatus') as HTMLParagraphElement;
  
  function slugify(text: string) {
    return text.toString().toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w\-]+/g, '')
      .replace(/\-\-+/g, '-')
      .replace(/^-+/, '')
      .replace(/-+$/, '');
  }

  function renderBlogForm(post: any, isNew: boolean) {
    blogForm.classList.remove('hidden');
    (document.getElementById('blogIsNew') as HTMLInputElement).value = isNew ? '1' : '0';
    (document.getElementById('blogSlug') as HTMLInputElement).value = post?.slug || '';
    (document.getElementById('blogTitle') as HTMLInputElement).value = post?.title || '';
    (document.getElementById('blogTitleZh') as HTMLInputElement).value = post?.title_zh || '';
    (document.getElementById('blogExcerpt') as HTMLTextAreaElement).value = post?.excerpt || '';
    (document.getElementById('blogExcerptZh') as HTMLTextAreaElement).value = post?.excerpt_zh || '';
    (document.getElementById('blogDate') as HTMLInputElement).value = post?.date || new Date().toISOString().split('T')[0];
    (document.getElementById('blogReadTime') as HTMLInputElement).value = post?.readTime || '3 menit baca';
    (document.getElementById('blogContent') as HTMLTextAreaElement).value = post?.content?.join('\n\n') || '';
    (document.getElementById('blogContentZh') as HTMLTextAreaElement).value = post?.content_zh?.join('\n\n') || '';
    
    if (isNew) {
      deleteBlogBtn.classList.add('hidden');
      blogSelect.value = '';
    } else {
      deleteBlogBtn.classList.remove('hidden');
    }
  }

  blogSelect?.addEventListener('change', (e) => {
    const slug = (e.target as HTMLSelectElement).value;
    if (!slug) {
      blogForm.classList.add('hidden');
      return;
    }
    const post = blogsData.find((b: any) => b.slug === slug);
    if (post) renderBlogForm(post, false);
  });

  newBlogBtn?.addEventListener('click', () => {
    renderBlogForm(null, true);
  });
  
  async function submitBlogData(updatedBlogs: any[]) {
    saveBlogBtn.disabled = true;
    saveBlogBtn.textContent = 'Menyimpan...';
    blogStatus.textContent = '';
    try {
      const res = await fetch('/api/save-blog', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updatedBlogs),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        blogStatus.textContent = '✓ Tersimpan! Website akan diperbarui dalam ~1-2 menit.';
        blogsData = updatedBlogs;
        // Re-render select options
        blogSelect.innerHTML = '<option value="">-- Pilih Artikel untuk Diedit --</option>' + 
          blogsData.map((b: any) => `<option value="${b.slug}">${b.title}</option>`).join('');
        blogSelect.value = (document.getElementById('blogSlug') as HTMLInputElement).value;
      } else {
        blogStatus.textContent = `✗ Gagal: ${data.error}`;
      }
    } catch (err) {
      blogStatus.textContent = `✗ Gagal: ${err}`;
    } finally {
      saveBlogBtn.disabled = false;
      saveBlogBtn.textContent = 'Simpan Artikel';
    }
  }

  blogForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const isNew = (document.getElementById('blogIsNew') as HTMLInputElement).value === '1';
    let slug = (document.getElementById('blogSlug') as HTMLInputElement).value;
    const title = (document.getElementById('blogTitle') as HTMLInputElement).value;
    
    if (isNew) {
      slug = slugify(title);
      let counter = 1;
      let origSlug = slug;
      while(blogsData.some((b: any) => b.slug === slug)) {
        slug = `${origSlug}-${counter}`;
        counter++;
      }
      (document.getElementById('blogSlug') as HTMLInputElement).value = slug;
    }
    
    const newPost = {
      slug,
      title,
      title_zh: (document.getElementById('blogTitleZh') as HTMLInputElement).value,
      excerpt: (document.getElementById('blogExcerpt') as HTMLTextAreaElement).value,
      excerpt_zh: (document.getElementById('blogExcerptZh') as HTMLTextAreaElement).value,
      date: (document.getElementById('blogDate') as HTMLInputElement).value,
      readTime: (document.getElementById('blogReadTime') as HTMLInputElement).value,
      content: (document.getElementById('blogContent') as HTMLTextAreaElement).value.split(/\n\s*\n/).filter(p => p.trim() !== ''),
      content_zh: (document.getElementById('blogContentZh') as HTMLTextAreaElement).value.split(/\n\s*\n/).filter(p => p.trim() !== '')
    };
    
    let newBlogsData = [...blogsData];
    if (isNew) {
      newBlogsData.unshift(newPost);
    } else {
      newBlogsData = newBlogsData.map((b: any) => b.slug === slug ? newPost : b);
    }
    await submitBlogData(newBlogsData);
    deleteBlogBtn.classList.remove('hidden');
    (document.getElementById('blogIsNew') as HTMLInputElement).value = '0';
  });

  deleteBlogBtn?.addEventListener('click', async () => {
    if (!confirm('Yakin ingin menghapus artikel ini? Tindakan ini tidak bisa dibatalkan.')) return;
    const slug = (document.getElementById('blogSlug') as HTMLInputElement).value;
    const newBlogsData = blogsData.filter((b: any) => b.slug !== slug);
    await submitBlogData(newBlogsData);
    blogForm.classList.add('hidden');
    blogSelect.value = '';
  });
</script>

