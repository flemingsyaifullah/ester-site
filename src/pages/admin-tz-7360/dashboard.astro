  deleteNewsBtn?.addEventListener('click', async () => {
    if (!confirm('Yakin ingin menghapus berita ini?')) return;
    const slug = (document.getElementById('newsSlug') as HTMLInputElement).value;
    const updated = newsData.filter((n: any) => n.slug !== slug);
    await submitNewsData(updated);
    newsForm.classList.add('hidden');
    newsSelect.value = '';
  });
</script>

<script id="logo2DataScript" type="application/json" set:html={JSON.stringify(logo2List)}></script>
<script>
  /* ---- Portfolio 2 JS ---- */
  let logo2Data: any[] = [];
  try {
    logo2Data = JSON.parse(document.getElementById('logo2DataScript')?.textContent || '[]');
  } catch(e) {}

  const logo2Grid = document.getElementById('logo2Grid') as HTMLDivElement;
  const logo2SaveStatus = document.getElementById('logo2SaveStatus') as HTMLParagraphElement;
  const logo2AddStatus = document.getElementById('logo2AddStatus') as HTMLParagraphElement;
  const logo2AddBtn = document.getElementById('logo2AddBtn') as HTMLButtonElement;
  const logo2NamaInput = document.getElementById('logo2Nama') as HTMLInputElement;
  const logo2PathInput = document.getElementById('logo2Path') as HTMLInputElement;
  const logo2FileInput = document.getElementById('logo2FileInput') as HTMLInputElement;
  const logo2FileNameSpan = document.getElementById('logo2FileName') as HTMLSpanElement;
  const logo2UploadStatus = document.getElementById('logo2UploadStatus') as HTMLParagraphElement;

  function slugifyLogo(text: string) {
    return text.toString().toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w\-]+/g, '')
      .replace(/\-\-+/g, '-')
      .replace(/^-+/, '')
      .replace(/-+$/, '') + '-' + Date.now();
  }

  function renderLogo2Card(item: any) {
    const div = document.createElement('div');
    div.className = 'logo2-item relative flex w-36 flex-col items-center gap-2 rounded-sm border border-line p-3';
    div.dataset.id = item.id;
    div.innerHTML = `
      <img src="${item.logo}" alt="${item.nama}" class="h-16 w-full object-contain" loading="lazy" />
      <p class="text-center font-body text-xs text-slate leading-snug">${item.nama}</p>
      <button type="button" class="logo2-delete-btn absolute -right-2 -top-2 flex h-5 w-5 items-center justify-center rounded-full bg-stamp text-paper font-mono text-xs leading-none hover:bg-red-600" title="Hapus">&#x2715;</button>
    `;
    return div;
  }

  async function saveLogo2Data(data: any[]) {
    logo2SaveStatus.textContent = 'Menyimpan...';
    try {
      const res = await fetch('/api/save-portfolio2', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (res.ok && result.ok) {
        logo2SaveStatus.textContent = '✓ Tersimpan! Website akan diperbarui dalam ~1–2 menit.';
        logo2Data = data;
      } else {
        logo2SaveStatus.textContent = `✗ Gagal: ${result.error}`;
      }
    } catch(err) {
      logo2SaveStatus.textContent = `✗ Error: ${err}`;
    }
  }

  // Handle file upload for logo
  logo2FileInput?.addEventListener('change', async () => {
    const file = logo2FileInput.files?.[0];
    if (!file) return;
    logo2FileNameSpan.textContent = file.name;
    logo2UploadStatus.textContent = 'Mengupload...';
    const fd = new FormData();
    fd.append('image', file);
    try {
      const res = await fetch('/api/upload-image', { method: 'POST', body: fd });
      const data = await res.json();
      if (res.ok && (data.path || data.url)) {
        logo2PathInput.value = data.path || data.url;
        logo2UploadStatus.textContent = '✓ Terupload! Klik "+ Tambah Logo" untuk menyimpan.';
      } else {
        logo2UploadStatus.textContent = `✗ Gagal: ${data.error}`;
      }
    } catch(e) {
      logo2UploadStatus.textContent = '✗ Terjadi kesalahan.';
    }
  });

  // Add new logo
  logo2AddBtn?.addEventListener('click', async () => {
    const nama = logo2NamaInput.value.trim();
    const logoPath = logo2PathInput.value.trim();
    if (!nama) { logo2AddStatus.textContent = '✗ Nama klien harus diisi.'; return; }
    if (!logoPath) { logo2AddStatus.textContent = '✗ Logo harus diupload terlebih dahulu.'; return; }

    const newItem = { id: slugifyLogo(nama), nama, logo: logoPath };
    const updated = [...logo2Data, newItem];

    // Render optimistically
    const noDataMsg = logo2Grid?.querySelector('p');
    if (noDataMsg) noDataMsg.remove();
    const card = renderLogo2Card(newItem);
    logo2Grid?.appendChild(card);
    attachDeleteBtn(card);

    // Clear form
    logo2NamaInput.value = '';
    logo2PathInput.value = '';
    logo2FileInput.value = '';
    logo2FileNameSpan.textContent = 'Belum dipilih';
    logo2UploadStatus.textContent = '';
    logo2AddStatus.textContent = '';

    await saveLogo2Data(updated);
  });

  // Delete logo handler
  function attachDeleteBtn(card: HTMLElement) {
    card.querySelector('.logo2-delete-btn')?.addEventListener('click', async () => {
      const id = card.dataset.id;
      if (!confirm('Hapus logo ini?')) return;
      card.remove();
      const updated = logo2Data.filter((i: any) => i.id !== id);
      await saveLogo2Data(updated);
    });
  }

  // Attach delete to server-rendered cards
  document.querySelectorAll<HTMLElement>('.logo2-item').forEach(card => attachDeleteBtn(card));
</script>

<script id="p3DataScript" type="application/json" set:html={JSON.stringify(proyek3List)}></script>
<script>
  /* ---- Portfolio 3 JS ---- */
  let p3Data: any[] = [];
  try {
    p3Data = JSON.parse(document.getElementById('p3DataScript')?.textContent || '[]');
  } catch(e) {}

  const p3Select = document.getElementById('p3Select') as HTMLSelectElement;
  const newP3Btn = document.getElementById('newP3Btn') as HTMLButtonElement;
  const p3Form = document.getElementById('p3Form') as HTMLFormElement;
  const deleteP3Btn = document.getElementById('deleteP3Btn') as HTMLButtonElement;
  const saveP3Btn = document.getElementById('saveP3Btn') as HTMLButtonElement;
  const p3Status = document.getElementById('p3Status') as HTMLParagraphElement;
  const p3FotoPath = document.getElementById('p3FotoPath') as HTMLInputElement;
  const p3ImgPreview = document.getElementById('p3ImgPreview') as HTMLImageElement;
  const p3ImgWrap = document.getElementById('p3ImgWrap') as HTMLDivElement;
  const p3UploadStatus = document.getElementById('p3UploadStatus') as HTMLParagraphElement;
  const p3RemoveFotoBtn = document.getElementById('p3RemoveFotoBtn') as HTMLButtonElement;

  function slugifyP3(text: string) {
    return text.toString().toLowerCase()
      .replace(/\s+/g, '-').replace(/[^\w\-]+/g, '')
      .replace(/\-\-+/g, '-').replace(/^-+/, '').replace(/-+$/, '')
      + '-' + Date.now();
  }

  function setP3Photo(path: string) {
    if (path) {
      p3FotoPath.value = path;
      p3ImgPreview.src = path;
      p3ImgWrap.classList.remove('hidden');
      p3RemoveFotoBtn.classList.remove('hidden');
    } else {
      p3FotoPath.value = '';
      p3ImgPreview.src = '';
      p3ImgWrap.classList.add('hidden');
      p3RemoveFotoBtn.classList.add('hidden');
    }
  }

  function renderP3Form(item: any, isNew: boolean) {
    p3Form.classList.remove('hidden');
    (document.getElementById('p3IsNew') as HTMLInputElement).value = isNew ? '1' : '0';

    if (isNew) {
      deleteP3Btn.classList.add('hidden');
      (document.getElementById('p3Id') as HTMLInputElement).value = '';
      (document.getElementById('p3Suspended') as HTMLInputElement).checked = false;
      ['p3Jenis','p3JenisZh','p3Luas','p3Tahun','p3Lokasi','p3LokasiZh','p3Narasi','p3NarasiZh','p3Hasil','p3HasilZh'].forEach(id => {
        (document.getElementById(id) as HTMLInputElement).value = '';
      });
      setP3Photo('');
    } else {
      deleteP3Btn.classList.remove('hidden');
      (document.getElementById('p3Id') as HTMLInputElement).value = item?.id || '';
      (document.getElementById('p3Suspended') as HTMLInputElement).checked = !!item?.suspended;
      (document.getElementById('p3Jenis') as HTMLInputElement).value = item?.jenis || '';
      (document.getElementById('p3JenisZh') as HTMLInputElement).value = item?.jenis_zh || '';
      (document.getElementById('p3Luas') as HTMLInputElement).value = item?.luas || '';
      (document.getElementById('p3Tahun') as HTMLInputElement).value = item?.tahun || '';
      (document.getElementById('p3Lokasi') as HTMLInputElement).value = item?.lokasi || '';
      (document.getElementById('p3LokasiZh') as HTMLInputElement).value = item?.lokasi_zh || '';
      (document.getElementById('p3Narasi') as HTMLTextAreaElement).value = item?.narasi || '';
      (document.getElementById('p3NarasiZh') as HTMLTextAreaElement).value = item?.narasi_zh || '';
      (document.getElementById('p3Hasil') as HTMLInputElement).value = item?.hasil || '';
      (document.getElementById('p3HasilZh') as HTMLInputElement).value = item?.hasil_zh || '';
      setP3Photo(item?.foto || '');
    }
    p3Status.textContent = '';
    p3UploadStatus.textContent = 'JPG / PNG / WebP, maks 5MB.';
  }

  p3Select?.addEventListener('change', (e) => {
    const id = (e.target as HTMLSelectElement).value;
    if (!id) { p3Form.classList.add('hidden'); return; }
    const item = p3Data.find((p: any) => p.id === id);
    if (item) renderP3Form(item, false);
  });

  newP3Btn?.addEventListener('click', () => {
    p3Select.value = '';
    renderP3Form(null, true);
  });

  p3RemoveFotoBtn?.addEventListener('click', () => {
    setP3Photo('');
    p3UploadStatus.textContent = 'Foto dihapus. Simpan proyek untuk mengonfirmasi.';
  });

  // Upload foto
  document.getElementById('p3ImageInput')?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    p3ImgPreview.src = URL.createObjectURL(file);
    p3ImgWrap.classList.remove('hidden');
    p3UploadStatus.textContent = 'Mengupload foto...';
    const fd = new FormData();
    fd.append('image', file);
    try {
      const res = await fetch('/api/upload-image', { method: 'POST', body: fd });
      const data = await res.json();
      if (res.ok && (data.path || data.url)) {
        p3FotoPath.value = data.path || data.url;
        p3RemoveFotoBtn.classList.remove('hidden');
        p3UploadStatus.textContent = '✓ Foto terupload! Jangan lupa Simpan Proyek.';
      } else {
        p3UploadStatus.textContent = `✗ Gagal upload: ${data.error}`;
      }
    } catch {
      p3UploadStatus.textContent = '✗ Terjadi kesalahan sistem.';
    }
  });

  async function submitP3Data(updated: any[]) {
    saveP3Btn.disabled = true;
    saveP3Btn.textContent = 'Menyimpan...';
    p3Status.textContent = '';
    try {
      const res = await fetch('/api/save-portfolio3', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updated),
      });
      const result = await res.json();
      if (res.ok && result.ok) {
        p3Status.textContent = '✓ Tersimpan! Website akan diperbarui dalam ~1–2 menit.';
        p3Data = updated;
        p3Select.innerHTML = '<option value="">-- Pilih Proyek untuk Diedit --</option>' +
          p3Data.map((p: any) => `<option value="${p.id}">${p.jenis}</option>`).join('');
        p3Select.value = (document.getElementById('p3Id') as HTMLInputElement).value;
      } else {
        p3Status.textContent = `✗ Gagal: ${result.error}`;
      }
    } catch (err) {
      p3Status.textContent = `✗ Gagal: ${err}`;
    } finally {
      saveP3Btn.disabled = false;
      saveP3Btn.textContent = 'Simpan Proyek';
    }
  }

  p3Form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const isNew = (document.getElementById('p3IsNew') as HTMLInputElement).value === '1';
    let id = (document.getElementById('p3Id') as HTMLInputElement).value;
    if (isNew) id = slugifyP3((document.getElementById('p3Jenis') as HTMLInputElement).value || 'proyek');

    const fotoVal = p3FotoPath.value.trim();
    const newItem: any = {
      id,
      suspended: !!(document.getElementById('p3Suspended') as HTMLInputElement).checked,
      jenis: (document.getElementById('p3Jenis') as HTMLInputElement).value,
      jenis_zh: (document.getElementById('p3JenisZh') as HTMLInputElement).value,
      luas: (document.getElementById('p3Luas') as HTMLInputElement).value,
      tahun: (document.getElementById('p3Tahun') as HTMLInputElement).value,
      lokasi: (document.getElementById('p3Lokasi') as HTMLInputElement).value,
      lokasi_zh: (document.getElementById('p3LokasiZh') as HTMLInputElement).value,
      narasi: (document.getElementById('p3Narasi') as HTMLTextAreaElement).value,
      narasi_zh: (document.getElementById('p3NarasiZh') as HTMLTextAreaElement).value,
      hasil: (document.getElementById('p3Hasil') as HTMLInputElement).value,
      hasil_zh: (document.getElementById('p3HasilZh') as HTMLInputElement).value,
    };
    if (fotoVal) {
      newItem.foto = fotoVal;
      newItem.fotoAlt = newItem.jenis;
    }

    let updated = [...p3Data];
    if (isNew) {
      updated.push(newItem);
      (document.getElementById('p3Id') as HTMLInputElement).value = id;
      (document.getElementById('p3IsNew') as HTMLInputElement).value = '0';
      deleteP3Btn.classList.remove('hidden');
    } else {
      updated = updated.map((p: any) => p.id === id ? newItem : p);
    }
    await submitP3Data(updated);
  });

  deleteP3Btn?.addEventListener('click', async () => {
    if (!confirm('Yakin ingin menghapus proyek ini secara PERMANEN? Gunakan Suspend jika hanya ingin menyembunyikan.')) return;
    const id = (document.getElementById('p3Id') as HTMLInputElement).value;
    const updated = p3Data.filter((p: any) => p.id !== id);
    deleteP3Btn.disabled = true;
    deleteP3Btn.textContent = 'Menghapus...';
    try {
      const res = await fetch('/api/save-portfolio3', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updated),
      });
      if (res.ok) { alert('Proyek berhasil dihapus.'); window.location.reload(); }
    } catch(e) {
      deleteP3Btn.disabled = false;
      deleteP3Btn.textContent = 'Hapus';
    }
  });
</script>
