    (document.getElementById('newsContentZh') as HTMLTextAreaElement).value = item?.content_zh?.join('\n\n') || '';
    if (isNew) { deleteNewsBtn.classList.add('hidden'); newsSelect.value = ''; }
    else { deleteNewsBtn.classList.remove('hidden'); }
  }

  newsSelect?.addEventListener('change', (e) => {
