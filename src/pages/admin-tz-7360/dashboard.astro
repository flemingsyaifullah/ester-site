  newNewsBtn?.addEventListener('click', () => renderNewsForm(null, true));

  async function submitNewsData(updatedNews: any[]) {
    saveNewsBtn.disabled = true;
    saveNewsBtn.textContent = 'Menyimpan...';
    newsStatus.textContent = '';
    try {
      const res = await fetch('/api/save-news', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updatedNews),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        newsStatus.textContent = '\u2713 Tersimpan! Website akan diperbarui dalam ~1-2 menit.';
        newsData = updatedNews;
        newsSelect.innerHTML = '<option value="">-- Pilih Berita untuk Diedit --</option>' +
          newsData.map((n: any) => `<option value="${n.slug}">${n.title}</option>`).join('');
        newsSelect.value = (document.getElementById('newsSlug') as HTMLInputElement).value;
      } else { newsStatus.textContent = `\u2717 Gagal: ${data.error}`; }
    } catch (err) {
      newsStatus.textContent = `\u2717 Gagal: ${err}`;
    } finally {
      saveNewsBtn.disabled = false;
      saveNewsBtn.textContent = 'Simpan Berita';
    }
  }

  newsForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const isNew = (document.getElementById('newsIsNew') as HTMLInputElement).value === '1';
    let slug = (document.getElementById('newsSlug') as HTMLInputElement).value;
    const title = (document.getElementById('newsTitle') as HTMLInputElement).value;
    if (isNew) {
      slug = slugifyNews(title);
      let counter = 1; let orig = slug;
      while(newsData.some((n: any) => n.slug === slug)) { slug = `${orig}-${counter}`; counter++; }
      (document.getElementById('newsSlug') as HTMLInputElement).value = slug;
    }
    const newItem = {
      slug, title,
      title_zh: (document.getElementById('newsTitleZh') as HTMLInputElement).value,
      excerpt: (document.getElementById('newsExcerpt') as HTMLTextAreaElement).value,
      excerpt_zh: (document.getElementById('newsExcerptZh') as HTMLTextAreaElement).value,
      date: (document.getElementById('newsDate') as HTMLInputElement).value,
