  const saveNewsBtn = document.getElementById('saveNewsBtn') as HTMLButtonElement;
  const newsStatus = document.getElementById('newsStatus') as HTMLParagraphElement;

  function slugifyNews(text: string) {
    return text.toString().toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w\-]+/g, '')
      .replace(/\-\-+/g, '-')
      .replace(/^-+/, '').replace(/-+$/, '');
  }

  function renderNewsForm(item: any, isNew: boolean) {
