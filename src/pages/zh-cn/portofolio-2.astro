---
import Layout from "../../layouts/Layout.astro";
import logos from "../../data/portfolio2.json";
---

<Layout
  title="客户案例 | Ester Globalindo"
  description="信任 Ester Globalindo 办理建筑许可证的企业与机构客户展示。"
  path="/zh-cn/portofolio-2"
>
  <!-- HERO -->
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-6xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/90">客户案例</p>
        <h1 class="mt-2 max-w-2xl text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          信任我们的合作伙伴
        </h1>
        <p class="mt-4 max-w-xl font-body text-paper/90 leading-relaxed">
          以下是跨行业信任我们专业服务的企业与机构，我们为他们提供建筑许可证一站式服务。
        </p>
      </div>
    </div>
  </section>

  <!-- LOGO GRID -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      {logos.length === 0 ? (
        <p class="font-body text-sm text-slate text-center py-20">暂无客户数据。</p>
      ) : (
        <div class="flex flex-wrap justify-center gap-8">
          {logos.map((item: any) => (
            <div class="group flex w-36 flex-col items-center gap-3 sm:w-44">
              <div class="flex h-24 w-full items-center justify-center overflow-hidden rounded-sm border border-line bg-paper p-3 shadow-sm transition-shadow group-hover:shadow-md">
                <img
                  src={item.logo}
                  alt={item.nama}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              </div>
              <p class="text-center font-body text-xs text-slate leading-snug">{item.nama}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
