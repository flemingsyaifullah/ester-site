---
import Layout from "../../../layouts/Layout.astro";
import posts from "../../../data/blog.json";

export function getStaticPaths() {
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const title = (post as any).title_zh || post.title;
const excerpt = (post as any).excerpt_zh || post.excerpt;
const content = (post as any).content_zh || post.content;
const waNumber = "6282230027878";
const waMsg = encodeURIComponent(`您好，我刚读了 "${title}" 这篇文章，想进一步咨询。`);
const lainnya = posts.filter((p) => p.slug !== post.slug).slice(0, 3);
---
<Layout
  title={`${title} | Ester Globalindo`}
  description={excerpt}
  path={`/zh-cn/blog/${post.slug}`}
>
  <article class="bg-paper">
    <div class="border-b border-line bg-[#5b7ec5] text-paper">
      <div class="blueprint-grid">
        <div class="mx-auto max-w-3xl px-5 py-14">
          <a href="/zh-cn/blog" class="font-mono text-xs uppercase tracking-wider text-paper/90 hover:text-white">&larr; 返回文章列表</a>
          <p class="mt-4 font-mono text-xs uppercase tracking-wider text-paper/90">
            {new Date(post.date).toLocaleDateString("zh-CN", { day: "numeric", month: "long", year: "numeric" })} · {post.readTime}
          </p>
          <h1 class="mt-2 text-balance font-display text-3xl font-bold leading-tight sm:text-4xl">{title}</h1>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-5 py-14">
      <div class="space-y-5">
        {content.map((para: string) => (
          <p class="font-body text-base leading-relaxed text-ink">{para}</p>
        ))}
      </div>

    </div>
  </article>

  <section class="border-t border-line bg-paper">
    <div class="mx-auto max-w-3xl px-5 py-14">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">更多文章</p>
      <div class="mt-6 grid gap-4">
        {lainnya.map((p) => (
          <a href={`/zh-cn/blog/${p.slug}`} class="rounded-sm border border-ink bg-paper px-5 py-4 transition-shadow hover:shadow-md">
            <h3 class="font-display font-bold text-ink">{(p as any).title_zh || p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
