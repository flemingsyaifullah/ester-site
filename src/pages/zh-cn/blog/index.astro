---
import Layout from "../../../layouts/Layout.astro";
import posts from "../../../data/blog.json";

const sorted = [...posts].sort((a, b) => (a.date < b.date ? 1 : -1));
---
<Layout
  title="建筑许可证 PBG & SLF 指南与文章 | Ester Globalindo"
  description="关于印度尼西亚建筑许可证 PBG、SLF 和建筑审批流程的权威指南文章合集。"
  path="/zh-cn/blog"
>
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-4xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/90">指南</p>
        <h1 class="mt-2 font-display text-4xl font-bold sm:text-5xl">建筑许可证文章</h1>
        <p class="mt-5 max-w-xl font-body text-paper/90">
          关于 PBG、SLF 及建筑许可证申请流程的文章合集——帮助您在咨询我们之前了解每个步骤。
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <div class="grid gap-6">
        {sorted.map((p) => (
          <a href={`/zh-cn/blog/${p.slug}`} class="group block rounded-sm border border-ink bg-paper p-6 transition-shadow hover:shadow-md">
            <p class="font-mono text-xs uppercase tracking-wider text-slate">
              {new Date(p.date).toLocaleDateString("zh-CN", { day: "numeric", month: "long", year: "numeric" })} · {p.readTime}
            </p>
            <h2 class="mt-2 font-display text-xl font-bold text-ink group-hover:underline">{(p as any).title_zh || p.title}</h2>
            <p class="mt-2 font-body text-sm leading-relaxed text-slate">{(p as any).excerpt_zh || p.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
