---
import Layout from "../../../layouts/Layout.astro";
import { daftarKota } from "../../../data/kota";

export function getStaticPaths() {
  return daftarKota.map((k) => ({
    params: { kota: k.slug },
    props: { kota: k },
  }));
}

const { kota } = Astro.props;
const waNumber = "6282230027878";
const waMsg = encodeURIComponent(`您好，我想咨询在 ${kota.nama} 办理 PBG/SLF 的相关事宜。`);
const kotaLain = daftarKota.filter((k) => k.slug !== kota.slug);
---
<Layout
  title={`${kota.nama} PBG & SLF 办理服务 | Ester Globalindo`}
  description={`${kota.nama} PBG 和 SLF 办理专业顾问。我们全程陪同，从准备文件到与 ${kota.dinas} 协调。`}
  path={`/zh-cn/area-layanan/${kota.slug}`}
>
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-4xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-blueprint-light">服务区域</p>
        <h1 class="mt-2 font-display text-4xl font-bold sm:text-5xl">
          {kota.nama} 及东爪哇 PBG &amp; SLF 办理
        </h1>
        <p class="mt-5 max-w-xl font-body text-blueprint-light">
          我们协助办理 {kota.nama} 及东爪哇的 PBG 和 SLF 流程，包括文件协调和与 {kota.dinas} 的技术咨询。
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">现场注意事项</p>
      <h2 class="mt-2 font-display text-2xl font-bold text-ink">在 {kota.nama} 办理需注意的事项</h2>
      <p class="mt-4 max-w-2xl font-body text-slate leading-relaxed">{kota.catatan_zh} (我们在当地的丰富经验确保顺利处理各项要求。)</p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <a href="/zh-cn/jasa-pbg" class="rounded-sm border-2 border-ink p-6 hover:bg-ink hover:text-paper">
          <h3 class="font-display font-bold">PBG 办理详情 &rarr;</h3>
        </a>
        <a href="/zh-cn/jasa-slf" class="rounded-sm border-2 border-ink p-6 hover:bg-ink hover:text-paper">
          <h3 class="font-display font-bold">SLF 办理详情 &rarr;</h3>
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-line bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-14">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">我们服务的其他城市</p>
      <div class="mt-6 flex flex-wrap gap-3">
        {kotaLain.map((k) => (
          <a href={`/zh-cn/area-layanan/${k.slug}`} class="rounded-sm border border-ink px-4 py-2 font-body text-sm text-ink hover:bg-ink hover:text-paper">
            {k.nama}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
