---
import Layout from "../../layouts/Layout.astro";
import portfolioData from "../../data/portfolio.json";

const proyek = (portfolioData as any).proyek?.filter((p: any) => !p.suspended) || [];
const waNumber = "6282230027878";
const waMsg = encodeURIComponent("您好，我想了解 Ester Globalindo 的项目案例。");
---
<Layout
  title="项目案例 | Ester Globalindo"
  description="Ester Globalindo 历年服务的建筑许可证项目案例，包括商业、工业及住宅建筑。"
  path="/zh-cn/portofolio"
>
  <section class="border-b border-line bg-blueprint-dark text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-6xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-blueprint-light">项目案例</p>
        <h1 class="mt-2 max-w-2xl text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          我们的成功案例
        </h1>
        <p class="mt-4 max-w-xl font-body text-blueprint-light leading-relaxed">
          客户的信任是我们最大的成就。以下是部分我们已成功协助完成 PBG 和 SLF 申请的客户案例。
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="space-y-20">
        {proyek.map((p: any) => (
          <article id={p.id} class="grid gap-10 md:grid-cols-2 md:items-start">
            <div class="overflow-hidden rounded-sm border-2 border-line">
              <img
                src={p.foto}
                alt={p.fotoAlt}
                class="h-72 w-full object-cover"
                loading="lazy"
              />
            </div>
            <div>
              <p class="font-mono text-xs uppercase tracking-widest text-stamp">{p.klien_zh || p.klien}</p>
              <h2 class="mt-2 font-display text-3xl font-bold text-ink">{p.nama_zh || p.nama}</h2>
              <p class="mt-1 font-mono text-xs text-slate tracking-wide">{p.lokasi_zh || p.lokasi}</p>

              <p class="mt-5 font-body text-sm leading-relaxed text-slate">{p.deskripsi_zh || p.deskripsi}</p>

              <div class="mt-8">
                <p class="font-mono text-xs uppercase tracking-widest text-stamp mb-4">成功获得的许可证</p>
                <div class="space-y-4">
                  {p.capaian?.map((c: any) => (
                    <div class="border-l-2 border-stamp pl-4">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="rounded-sm bg-blueprint px-2 py-0.5 font-mono text-[10px] font-medium tracking-wider text-paper">
                          {c.kode}
                        </span>
                        <span class="font-display font-bold text-ink">{c.label_zh || c.label}</span>
                      </div>
                      <p class="font-body text-sm text-slate leading-relaxed">{c.desc_zh || c.desc}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>


</Layout>
