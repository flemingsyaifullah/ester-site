---
import Layout from "../../layouts/Layout.astro";

const waNumber = "6282230027878";
const waMsg = encodeURIComponent("您好，我想咨询 SLF 建筑合格证书办理业务。");

const poin = [
  { judul: "使用前必备", desc: "在建筑物正式运营或出租前，必须先取得 SLF 证书。" },
  { judul: "有效期限制", desc: "住宅建筑有效期 20 年，非住宅建筑有效期 5 年，到期须续期。" },
  { judul: "法律合规要求", desc: "根据《就业创造法》及 PP 16/2021 条例，SLF 是法律强制要求的证件。" },
  { judul: "银行融资条件", desc: "大多数商业银行要求企业贷款申请人持有有效的 SLF 证书。" },
];
---
<Layout
  title="SLF 建筑合格证书代办服务 | Ester Globalindo"
  description="专业代办印度尼西亚 SLF（建筑合格证书）申请服务，确保建筑合法合规运营。服务泗水及东爪哇地区。"
  path="/zh-cn/jasa-slf"
>
  <!-- HERO -->
  <section class="border-b border-line bg-blueprint-dark text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-6xl px-5 py-16 md:py-24">
        <span class="inline-block rounded-sm bg-blueprint px-3 py-1 font-mono text-xs font-medium tracking-wider text-paper">SLF</span>
        <h1 class="mt-4 text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          建筑合格证书<br />代办服务
        </h1>
        <p class="mt-5 max-w-2xl font-body text-base leading-relaxed text-blueprint-light">
          SLF（Sertifikat Laik Fungsi）是证明已竣工建筑真正适合且安全用于运营或居住的法定证书，是建筑物正式交付使用前的必备文件。
        </p>
        <a
          href={`https://wa.me/${waNumber}?text=${waMsg}`}
          target="_blank" rel="noopener noreferrer"
          class="mt-8 inline-block rounded-sm border-2 border-paper px-6 py-3 font-mono text-sm font-medium uppercase tracking-wider text-paper transition-colors hover:bg-white/10"
        >
          免费咨询 SLF 申请
        </a>
      </div>
    </div>
  </section>

  <!-- WHY SLF -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">为何重要</p>
      <h2 class="mt-2 font-display text-3xl font-bold text-ink">为什么 SLF 不可缺少？</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {poin.map((p) => (
          <div class="rounded-sm border-2 border-line bg-paper-dim p-6">
            <h3 class="font-display text-lg font-bold text-ink">{p.judul}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-slate">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
</Layout>
