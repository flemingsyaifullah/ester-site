---
import Layout from "../../layouts/Layout.astro";

const waNumber = "6282230027878";
const waMsg = encodeURIComponent("您好，我想咨询 PBG 建筑审批许可证办理业务。");

const langkah = [
  { no: "01", judul: "文件准备", desc: "准备土地证明（SHM/HGB）、PKKPR/KRK 文件及建筑技术图纸。" },
  { no: "02", judul: "SIMBG 系统注册", desc: "通过建筑信息管理系统（SIMBG）上传所有申请文件。" },
  { no: "03", judul: "技术部门核查", desc: "技术部门对文件进行行政验证和技术审核。" },
  { no: "04", judul: "TPA/TPT 咨询", desc: "与技术评估团队（TPA/TPT）进行咨询，确认文件合规性。" },
  { no: "05", judul: "修订与再确认", desc: "根据评估意见修订文件，直至获得批准。" },
  { no: "06", judul: "PBG 证书颁发", desc: "缴纳相关税费后，PBG 证书正式颁发。" },
];

const dokumen = [
  "土地所有权证明（SHM/HGB）",
  "业主身份证（KTP）",
  "PKKPR/KRK 空间规划文件",
  "建筑设计方案图（Arsitek）",
  "结构计算书（Struktur）",
  "机电设备图纸（MEP）",
  "UKL-UPL / SPPL 环评文件",
];
---
<Layout
  title="PBG 建筑审批许可证代办服务 | Ester Globalindo"
  description="专业代办印度尼西亚 PBG（建筑审批许可证）申请服务，取代原 IMB。服务泗水及东爪哇地区。"
  path="/zh-cn/jasa-pbg"
>
  <!-- HERO -->
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-4xl px-5 py-10">
        <span class="inline-block rounded-sm bg-blueprint px-3 py-1 font-mono text-xs font-medium tracking-wider text-paper">PBG</span>
        <h1 class="mt-4 text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          建筑审批许可证<br />代办服务
        </h1>
        <p class="mt-5 max-w-2xl font-body text-base leading-relaxed text-blueprint-light">
          PBG（Persetujuan Bangunan Gedung）是根据《就业创造法》取代原 IMB 的新建筑许可证，是在印度尼西亚进行任何建设施工的必备法定文件。
        </p>
        <a
          href={`https://wa.me/${waNumber}?text=${waMsg}`}
          target="_blank" rel="noopener noreferrer"
          class="mt-8 inline-block rounded-sm border-2 border-paper px-6 py-3 font-mono text-sm font-medium uppercase tracking-wider text-paper transition-colors hover:bg-white/10"
        >
          免费咨询 PBG 申请
        </a>
      </div>
    </div>
  </section>

  <!-- STEPS -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">申请流程</p>
      <h2 class="mt-2 font-display text-3xl font-bold text-ink">PBG 申请步骤</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {langkah.map((l) => (
          <div class="rounded-sm border-2 border-line bg-paper p-6">
            <p class="font-mono text-3xl font-bold text-blueprint">{l.no}</p>
            <h3 class="mt-3 font-display text-lg font-bold text-ink">{l.judul}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-slate">{l.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCUMENTS -->
  <section class="border-y border-line bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">所需文件</p>
      <h2 class="mt-2 font-display text-3xl font-bold text-ink">申请所需主要文件</h2>
      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {dokumen.map((d) => (
          <li class="flex items-start gap-3 rounded-sm border border-line bg-paper p-4">
            <span class="mt-0.5 flex-shrink-0 text-blueprint">✓</span>
            <span class="font-body text-sm text-ink">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Layout>
