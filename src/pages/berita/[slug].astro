---
import Layout from "../../layouts/Layout.astro";
import news from "../../data/news.json";

export function getStaticPaths() {
  return news.map((n) => ({
    params: { slug: n.slug },
    props: { item: n },
  }));
}

const { item } = Astro.props;
const waNumber = "6282230027878";
const waMsg = encodeURIComponent(`Halo, saya baru baca berita "${item.title}" dan ingin konsultasi lebih lanjut.`);
const lainnya = news.filter((n) => n.slug !== item.slug).slice(0, 3);
---
<Layout
  title={`${item.title} | Berita Ester Globalindo`}
  description={item.excerpt}
  path={`/berita/${item.slug}`}
>
  <article class="bg-paper">
    <div class="border-b border-line bg-[#5b7ec5] text-paper">
      <div class="blueprint-grid">
        <div class="mx-auto max-w-3xl px-5 py-14">
          <a href="/berita" class="font-mono text-xs uppercase tracking-wider text-paper/90 hover:text-white">&larr; Kembali ke Berita</a>
          <p class="mt-4 font-mono text-xs uppercase tracking-wider text-paper/90">
            {new Date(item.date).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" })} · {item.readTime}
          </p>
          <h1 class="mt-2 text-balance font-display text-3xl font-bold leading-tight sm:text-4xl">{item.title}</h1>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-5 py-14">
      <div class="space-y-5">
        {item.content.map((para) => (
          <p class="font-body text-base leading-relaxed text-ink">{para}</p>
        ))}
      </div>

    </div>
  </article>

  {lainnya.length > 0 && (
    <section class="border-t border-line bg-paper">
      <div class="mx-auto max-w-3xl px-5 py-14">
        <p class="font-mono text-xs uppercase tracking-widest text-stamp">Berita lain</p>
        <div class="mt-6 grid gap-4">
          {lainnya.map((n) => (
            <a href={`/berita/${n.slug}`} class="rounded-sm border border-line bg-paper px-5 py-4 hover:border-ink">
              <h3 class="font-display font-bold text-ink">{n.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
