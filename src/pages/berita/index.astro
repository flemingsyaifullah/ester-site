---
import Layout from "../../layouts/Layout.astro";
import news from "../../data/news.json";

const sorted = [...news].sort((a, b) => (a.date < b.date ? 1 : -1));
---
<Layout
  title="Berita Terkini Perizinan Bangunan PBG & SLF | Ester Globalindo"
  description="Berita terbaru seputar regulasi perizinan bangunan, PBG, SLF, dan kebijakan tata ruang di Surabaya dan seluruh Indonesia."
  path="/berita"
>
  <section class="border-b border-line bg-blueprint-dark text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-4xl px-5 py-16">
        <p class="font-mono text-xs uppercase tracking-widest text-blueprint-light">Terkini</p>
        <h1 class="mt-2 font-display text-4xl font-bold sm:text-5xl">Berita Perizinan</h1>
        <p class="mt-5 max-w-xl font-body text-blueprint-light">
          Perkembangan terkini seputar regulasi PBG, SLF, dan kebijakan perizinan bangunan
          yang perlu diketahui pemilik properti dan pelaku usaha.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <div class="grid gap-6">
        {sorted.map((n) => (
          <a href={`/berita/${n.slug}`} class="group block rounded-sm border border-line bg-paper-dim p-6 transition-colors hover:border-ink">
            <p class="font-mono text-xs uppercase tracking-wider text-slate">
              {new Date(n.date).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" })} · {n.readTime}
            </p>
            <h2 class="mt-2 font-display text-xl font-bold text-ink group-hover:underline">{n.title}</h2>
            <p class="mt-2 font-body text-sm leading-relaxed text-slate">{n.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
