---
import Layout from "../../layouts/Layout.astro";
import news from "../../data/news.json";

export async function getStaticPaths({ paginate }) {
  const sorted = [...news].sort((a, b) => (a.date < b.date ? 1 : -1));
  return paginate(sorted, { pageSize: 15 });
}

const { page } = Astro.props;
const isFirst = page.currentPage === 1;
const isLast = page.currentPage === page.lastPage;
const firstUrl = "/berita";
const lastUrl = page.lastPage === 1 ? "/berita" : `/berita/${page.lastPage}`;

const allNews = [...news].sort((a, b) => (a.date < b.date ? 1 : -1));
---
<Layout
  title="Berita Terkini Perizinan Bangunan PBG & SLF | Ester Globalindo"
  description="Berita terbaru seputar regulasi perizinan bangunan, PBG, SLF, dan kebijakan tata ruang di Surabaya dan seluruh Indonesia."
  path="/berita"
>
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-4xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/90">Terkini</p>
        <h1 class="mt-2 font-display text-4xl font-bold sm:text-5xl">Berita Perizinan</h1>
        <p class="mt-5 max-w-xl font-body text-paper/90">
          Perkembangan terkini seputar regulasi PBG, SLF, dan kebijakan perizinan bangunan
          yang perlu diketahui pemilik properti dan pelaku usaha.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-16">

      <!-- Search Box -->
      <div class="mb-10">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-slate pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="news-search"
            type="text"
            placeholder="Cari berita, misal: SLF, audit, Surabaya..."
            class="w-full rounded-sm border border-ink bg-paper py-3 pl-11 pr-4 font-body text-sm text-ink placeholder:text-slate/60 focus:outline-none focus:ring-2 focus:ring-blueprint"
          />
        </div>
        <p id="search-count" class="mt-2 font-mono text-xs text-slate hidden"></p>
      </div>

      <!-- Paginated list (default) -->
      <div id="paginated-list">
        <div class="grid gap-6">
          {page.data.map((n) => (
            <a href={`/berita/${n.slug}`} class="group block rounded-sm border border-ink bg-paper p-6 transition-shadow hover:shadow-md">
              <p class="font-mono text-xs uppercase tracking-wider text-slate">
                {new Date(n.date).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" })} · {n.readTime}
              </p>
              <h2 class="mt-2 font-display text-xl font-bold text-ink group-hover:underline">{n.title}</h2>
              <p class="mt-2 font-body text-sm leading-relaxed text-slate">{n.excerpt}</p>
            </a>
          ))}
        </div>

        <div class="mt-12 flex flex-wrap items-center justify-center gap-2 font-mono text-xs uppercase tracking-wider">
          {isFirst ? (
            <span class="border border-line/20 px-3 py-2 text-ink/30 pointer-events-none">|&lt; First</span>
          ) : (
            <a href={firstUrl} class="border border-line/50 px-3 py-2 text-ink transition-colors hover:bg-blueprint hover:border-blueprint hover:text-white">|&lt; First</a>
          )}

          {page.url.prev ? (
            <a href={page.url.prev} class="border border-line/50 px-3 py-2 text-ink transition-colors hover:bg-blueprint hover:border-blueprint hover:text-white">&larr; Prev</a>
          ) : (
            <span class="border border-line/20 px-3 py-2 text-ink/30 pointer-events-none">&larr; Prev</span>
          )}

          <span class="border border-blueprint bg-blueprint/10 px-4 py-2 text-ink">
            Page {page.currentPage} of {Math.max(1, page.lastPage)}
          </span>

          {page.url.next ? (
            <a href={page.url.next} class="border border-line/50 px-3 py-2 text-ink transition-colors hover:bg-blueprint hover:border-blueprint hover:text-white">Next &rarr;</a>
          ) : (
            <span class="border border-line/20 px-3 py-2 text-ink/30 pointer-events-none">Next &rarr;</span>
          )}

          {isLast ? (
            <span class="border border-line/20 px-3 py-2 text-ink/30 pointer-events-none">Last &gt;|</span>
          ) : (
            <a href={lastUrl} class="border border-line/50 px-3 py-2 text-ink transition-colors hover:bg-blueprint hover:border-blueprint hover:text-white">Last &gt;|</a>
          )}
        </div>
      </div>

      <!-- Search results (shown when searching) -->
      <div id="search-results" class="hidden">
        <div id="search-results-list" class="grid gap-6"></div>
        <p id="search-empty" class="hidden py-16 text-center font-body text-slate">Tidak ada berita yang cocok dengan pencarian Anda.</p>
      </div>

    </div>
  </section>
</Layout>

<script define:vars={{ allNews }}>
  const input = document.getElementById('news-search');
  const paginatedList = document.getElementById('paginated-list');
  const searchResults = document.getElementById('search-results');
  const searchResultsList = document.getElementById('search-results-list');
  const searchEmpty = document.getElementById('search-empty');
  const searchCount = document.getElementById('search-count');

  function formatDate(dateStr) {
    return new Date(dateStr).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function renderCard(n) {
    return `<a href="/berita/${n.slug}" class="group block rounded-sm border border-ink bg-paper p-6 transition-shadow hover:shadow-md">
      <p class="font-mono text-xs uppercase tracking-wider text-slate">${formatDate(n.date)} · ${n.readTime}</p>
      <h2 class="mt-2 font-display text-xl font-bold text-ink group-hover:underline">${n.title}</h2>
      <p class="mt-2 font-body text-sm leading-relaxed text-slate">${n.excerpt}</p>
    </a>`;
  }

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();

    if (q.length === 0) {
      paginatedList.classList.remove('hidden');
      searchResults.classList.add('hidden');
      searchCount.classList.add('hidden');
      return;
    }

    paginatedList.classList.add('hidden');
    searchResults.classList.remove('hidden');

    const filtered = allNews.filter(n =>
      n.title.toLowerCase().includes(q) ||
      n.excerpt.toLowerCase().includes(q)
    );

    searchCount.textContent = `${filtered.length} berita ditemukan`;
    searchCount.classList.remove('hidden');

    if (filtered.length === 0) {
      searchResultsList.innerHTML = '';
      searchEmpty.classList.remove('hidden');
    } else {
      searchEmpty.classList.add('hidden');
      searchResultsList.innerHTML = filtered.map(renderCard).join('');
    }
  });
</script>
