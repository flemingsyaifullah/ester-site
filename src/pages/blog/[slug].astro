---
import Layout from "../../layouts/Layout.astro";
import posts from "../../data/blog.json";

export function getStaticPaths() {
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const waNumber = "6282230027878";
const waMsg = encodeURIComponent(`Halo, saya baru baca artikel "${post.title}" dan ingin konsultasi lebih lanjut.`);
const lainnya = posts.filter((p) => p.slug !== post.slug).slice(0, 3);
---
<Layout
  title={`${post.title} | Blog Ester Globalindo`}
  description={post.excerpt}
  path={`/blog/${post.slug}`}
>
  <article class="bg-paper">
    <div class="border-b border-line bg-blueprint-dark text-paper">
      <div class="blueprint-grid">
        <div class="mx-auto max-w-3xl px-5 py-14">
          <a href="/blog" class="font-mono text-xs uppercase tracking-wider text-blueprint-light hover:text-white">&larr; Kembali ke Blog</a>
          <p class="mt-4 font-mono text-xs uppercase tracking-wider text-blueprint-light">
            {new Date(post.date).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" })} · {post.readTime}
          </p>
          <h1 class="mt-2 text-balance font-display text-3xl font-bold leading-tight sm:text-4xl">{post.title}</h1>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-5 py-14">
      <div class="space-y-5">
        {post.content.map((para) => (
          <p class="font-body text-base leading-relaxed text-ink">{para}</p>
        ))}
      </div>

    </div>
  </article>

  <section class="border-t border-line bg-paper-dim">
    <div class="mx-auto max-w-3xl px-5 py-14">
      <p class="font-mono text-xs uppercase tracking-widest text-stamp">Artikel lain</p>
      <div class="mt-6 grid gap-4">
        {lainnya.map((p) => (
          <a href={`/blog/${p.slug}`} class="rounded-sm border border-line bg-paper px-5 py-4 hover:border-ink">
            <h3 class="font-display font-bold text-ink">{p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
