---
import Layout from "../layouts/Layout.astro";
import logos from "../data/portfolio2.json";
---

<Layout
  title="Portofolio Klien | Ester Globalindo"
  description="Klien-klien yang telah mempercayakan pengurusan perizinan bangunan kepada Ester Globalindo di Surabaya dan Jawa Timur."
  path="/portofolio-2"
>
  <!-- HERO -->
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-6xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/90">Portofolio</p>
        <h1 class="mt-2 max-w-2xl text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          Klien yang Telah Mempercayai Kami
        </h1>
        <p class="mt-4 max-w-xl font-body text-paper/90 leading-relaxed">
          Kepercayaan dari berbagai klien lintas sektor adalah kebanggaan kami. Berikut perusahaan dan institusi yang telah kami layani.
        </p>
      </div>
    </div>
  </section>

  <!-- LOGO GRID -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      {logos.length > 0 && (
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
          {logos.map((item: any) => (
            <div class="flex w-32 items-center justify-center sm:w-40">
              <img
                src={item.logo}
                alt={item.nama}
                class="max-h-24 max-w-full object-contain"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
