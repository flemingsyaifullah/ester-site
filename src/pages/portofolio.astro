---
import Layout from "../layouts/Layout.astro";
import portfolioData from "../data/portfolio.json";

const waNumber = "6282230027878";
const waMsg = encodeURIComponent("Halo, saya ingin konsultasi soal pengurusan perizinan");

const proyek = portfolioData.proyek.filter((p: any) => !p.suspended);
---


<Layout
  title="Portofolio Proyek | Ester Globalindo"
  description="Portofolio proyek pengurusan PBG dan SLF oleh Ester Globalindo, termasuk Prodia Laboratory Mojokerto dan proyek bangunan komersial lainnya di Jawa Timur."
  path="/portofolio"
>
  <!-- HERO -->
  <section class="border-b border-line bg-[#5b7ec5] text-paper">
    <div class="blueprint-grid">
      <div class="mx-auto max-w-6xl px-5 py-10">
        <p class="font-mono text-xs uppercase tracking-widest text-paper/90">Portofolio</p>
        <h1 class="mt-2 max-w-2xl text-balance font-display text-4xl font-bold leading-tight sm:text-5xl">
          Proyek yang Telah Kami Tangani
        </h1>
        <p class="mt-4 max-w-xl font-body text-paper/90 leading-relaxed">
          Kepercayaan klien adalah pencapaian terbaik kami. Berikut sebagian proyek pengurusan PBG
          dan SLF yang telah berhasil kami selesaikan.
        </p>
      </div>
    </div>
  </section>

  <!-- PROYEK LIST -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="space-y-20">
        {proyek.map((p) => (
          <article id={p.id} class="grid gap-10 md:grid-cols-2 md:items-start">
            <!-- Foto -->
            <div class="overflow-hidden rounded-sm border-2 border-line">
              <img
                src={p.foto}
                alt={p.fotoAlt}
                class="h-72 w-full object-cover"
                loading="lazy"
              />
            </div>

            <!-- Detail -->
            <div>
              <p class="font-mono text-xs uppercase tracking-widest text-stamp">{p.klien}</p>
              <h2 class="mt-2 font-display text-3xl font-bold text-ink">{p.nama}</h2>
              <p class="mt-1 font-mono text-xs text-slate tracking-wide">{p.lokasi}</p>

              <p class="mt-5 font-body text-sm leading-relaxed text-slate">{p.deskripsi}</p>

              <!-- Capaian / Izin yang didapat -->
              <div class="mt-8">
                <p class="font-mono text-xs uppercase tracking-widest text-stamp mb-4">Izin yang Berhasil Diterbitkan</p>
                <div class="space-y-4">
                  {p.capaian.map((c) => (
                    <div class="border-l-2 border-stamp pl-4">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="rounded-sm bg-blueprint px-2 py-0.5 font-mono text-[10px] font-medium tracking-wider text-paper">
                          {c.kode}
                        </span>
                        <span class="font-display font-bold text-ink">{c.label}</span>
                      </div>
                      <p class="font-body text-sm text-slate leading-relaxed">{c.desc}</p>
                    </div>
                  ))}
                </div>
              </div>


            </div>
          </article>
        ))}
      </div>
    </div>
  </section>


</Layout>
