---
export interface Props {
  size?: number;
  label?: string;
  sub?: string;
  class?: string;
}
const { size = 128, label = "DISETUJUI", sub = "PBG · SLF", class: klass = "" } = Astro.props;
---
<svg
  class={`stamp-pop ${klass}`}
  width={size}
  height={size}
  viewBox="0 0 200 200"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={`Stempel ${label}`}
>
  <circle cx="100" cy="100" r="92" fill="none" stroke="var(--color-stamp)" stroke-width="2" opacity="0.9" />
  <circle cx="100" cy="100" r="78" fill="none" stroke="var(--color-stamp)" stroke-width="2.5" opacity="0.7" />
  <path id="stampCircleTop" d="M 18 100 A 82 82 0 0 1 182 100" fill="none" />
  <text font-family="var(--font-mono)" font-size="9" fill="var(--color-stamp)" letter-spacing="2">
    <textPath href="#stampCircleTop" startOffset="17%">JASA PERIZINAN BANGUNAN</textPath>
  </text>
  <text x="100" y="93" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="26" fill="var(--color-stamp)">
    {label}
  </text>
  <text x="100" y="118" text-anchor="middle" font-family="var(--font-mono)" font-size="13" letter-spacing="2" fill="var(--color-stamp)">
    {sub}
  </text>
  <line x1="45" y1="132" x2="155" y2="132" stroke="var(--color-stamp)" stroke-width="2" opacity="0.6" />
</svg>
