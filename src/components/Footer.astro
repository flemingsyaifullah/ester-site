---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const waNumber = "6282230027878";
const waMsg = encodeURIComponent("Halo, saya ingin konsultasi soal pengurusan PBG/SLF.");
---
<footer class="border-t border-line bg-blueprint-dark text-paper pt-10 pb-6">
  <div class="blueprint-grid">
    <div class="mx-auto max-w-6xl px-5 py-8">
      <div class="grid gap-10 md:grid-cols-4">
        <div class="md:col-span-2">
          <div class="mb-3 flex items-center gap-2">
            <span class="font-display text-lg font-bold text-paper">ESTER GLOBALINDO</span>
          </div>
          <p class="max-w-sm font-body text-sm leading-relaxed text-blueprint-light">
            {t('footer.about')}
          </p>
        </div>

        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-widest text-blueprint-light">{t('footer.services')}</p>
          <ul class="space-y-2 font-body text-sm">
            <li><a href={translatePath("/jasa-pbg")} class="hover:text-white">{t('nav.pbg')}</a></li>
            <li><a href={translatePath("/jasa-slf")} class="hover:text-white">{t('nav.slf')}</a></li>
            <li><a href={translatePath("/blog")} class="hover:text-white">{t('nav.blog')}</a></li>
            <li><a href={translatePath("/berita")} class="hover:text-white">{t('nav.news')}</a></li>
            <li><a href={translatePath("/portofolio")} class="hover:text-white">{t('nav.portfolio')}</a></li>
            <li><a href={translatePath("/brosur")} class="hover:text-white">{t('nav.brochure')}</a></li>
          </ul>
        </div>

        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-widest text-blueprint-light">{t('footer.contact')}</p>
          <ul class="space-y-2 font-body text-sm">
            <li>
              <a href="mailto:ester.globalindo@gmail.com" class="hover:text-white">ester.globalindo@gmail.com</a>
            </li>
            <li>
              <a href="tel:+6282230027878" class="hover:text-white">+62 822-3002-7878</a>
            </li>
            <li class="pt-2">
              Surabaya, Jawa Timur<br/>
              Indonesia
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mx-auto mt-8 max-w-6xl border-t border-line/10 px-5 pt-6">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="font-body text-sm text-slate">
          &copy; {new Date().getFullYear()} Ester Globalindo
        </p>
        <div class="flex gap-4 font-body text-sm text-slate">
          <a href="#" class="hover:text-white">{t('footer.privacy')}</a>
          <a href="#" class="hover:text-white">{t('footer.terms')}</a>
        </div>
      </div>
    </div>
  </div>
</footer>
