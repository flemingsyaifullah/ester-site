# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git!

# === Admin Credentials ===
# Username dan password untuk login ke /admin
ADMIN_USER=admin
ADMIN_PASS=ganti_password_ini

# === JWT Secret ===
# String acak panjang untuk signing JWT token
# Generate contoh: openssl rand -base64 32
JWT_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter

# === GitHub API (untuk simpan konten) ===
# Personal Access Token dari https://github.com/settings/tokens
# Scope yang dibutuhkan: repo (full control)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Nama repo dalam format: username/nama-repo
GITHUB_REPO=flemingsyaifullah/ester-site

# Branch yang dipakai (default: main)
GITHUB_BRANCH=main
